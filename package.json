{
  "name": "playwright-automation-framework",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "npx cucumber-js --profile front --tags @Smoke --retry 1",
    "allTests": "npx cucumber-js test",
    "report": "npx ts-node src/reports/front/report-generator.js",
    "report-default": "node generate-report.ts",
    "load": "npx artillery run src/performance-test/artillery/load-test.yaml --output src/reports/performance/artillery/report.json",
    "load-report": "node src/reports/performance/artillery/generate-report.js",
    "load-report-cloud": "npx artillery run src/performance-test/artillery/load-test.yaml --record --key YOUR--KEY--HERE",
    "bootstrap:k6:win": "powershell -ExecutionPolicy Bypass -File src/performance-test/k6/scripts/bootstrap-k6.ps1",
    "bootstrap:k6": "node -e \"process.platform==='win32'?process.exit(0):process.exit(1)\" && npm run bootstrap:k6:win || npm run bootstrap:k6:nix",
    "k6:build": "node src/performance-test/k6/esbuild.k6.config.mjs",
    "k6::smoke": "dotenv -e .env -- .\\src\\tools\\k6\\k6.exe run .\\src\\performance-test\\k6\\dist\\http\\smoke.js",
    "k6:stress": "dotenv -e .env -- .\\src\\tools\\k6\\k6.exe run .\\src\\performance-test\\k6\\dist\\http\\stress.js",
    "k6:soak": "dotenv -e .env -- .\\src\\tools\\k6\\k6.exe run .\\src\\performance-test\\k6\\dist\\http\\soak.js",
    "k6:spike": "dotenv -e .env -- .\\src\\tools\\k6\\k6.exe run .\\src\\performance-test\\k6\\dist\\http\\spike.js",
    "k6:run:browser": "dotenv -e .env -- .\\src\\tools\\k6\\k6.exe run .\\src\\performance-test\\k6\\dist\\browser\\example.browser.js",
    "apiTest": "npx cucumber-js --profile api --tags @API",
    "api-report": "node src/reports/api/report-generator.js",
    "mobile": "npx wdio run src/mobile-test/support/wdio.conf.ts",
    "mobile-report": "ts-node src/reports/mobile/generate-report.ts",
    "crawler": "ts-node src/tools/crawler/locators-generator.ts",
    "link-tester": "npx ts-node src/tools/link-tester/tester.ts",
    "link-tester:full": "npx ts-node src/tools/link-tester/tester.ts -full",
    "debug": "cross-env CUCUMBER_DEBUG=1 npx cucumber-js --profile debug",
    "record": "node src/tools/generator/codegen.js",
    "record:generator": "ts-node src/tools/generator/record-generator.ts"
  },
  "keywords": [],
  "author": "Danilo Vezzoni",
    "colaboradores": [
    "Yanko Leta",
    "Gianella Vezzoni",
    "Maximiliano Pintos"
  ],
  "license": "ISC",
  "description": "k0lmena automation framework",
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "@wdio/appium-service": "^9.29.1",
    "@wdio/browserstack-service": "^9.29.1",
    "@wdio/cli": "^9.29.1",
    "@wdio/cucumber-framework": "^9.29.1",
    "@wdio/globals": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/spec-reporter": "^9.29.1",
    "appium": "^3.5.2",
    "artillery": "^2.0.33",
    "artillery-engine-playwright": "^1.30.0",
    "cross-env": "^10.1.0",
    "cucumber-html-reporter": "^7.2.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "esbuild": "^0.28.1",
    "globby": "^16.2.0",
    "multiple-cucumber-html-reporter": "^4.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "webdriverio": "^9.29.1"
  },
  "dependencies": {
    "@artilleryio/playwright-reporter": "^1.1.3",
    "artillery-plugin-html-report": "^2.0.0",
    "axios": "^1.18.1",
    "cheerio": "^1.2.0"
  },
  "overrides": {
    "@grpc/grpc-js": "^1.14.4",
    "semver": "^7.8.5",
    "tmp": "^0.2.7",
    "esbuild": "^0.28.1",
    "undici": "^6.27.0",
    "uuid": "^11.1.1",
    "@opentelemetry/core": "^2.8.0",
    "playwright-core": "1.61.1",
    "playwright": "1.61.1",
    "@playwright/browser-chromium": "1.61.1",
    "reflect-metadata": "^0.2.2"
  }
}
