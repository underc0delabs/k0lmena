{
  "compilerOptions": {
    "strict": false,
    "skipLibCheck": true,
    "noErrorTruncation": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "lib": ["esnext", "dom"],
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "target": "esnext",
    "module": "commonjs",
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["src/performance-test/k6", "node_modules"]
}
